{
	"name": "project-recipes",
	"version": "1.0.0",
	"description": "Full-stack application with Next.js frontend and NestJS backend",
	"private": true,
	"scripts": {
		"dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" --names \"FRONTEND,BACKEND\" --prefix-colors \"cyan,magenta\"",
		"dev:frontend": "cd frontend && npm run dev",
		"dev:backend": "cd backend && npm run start:dev",
		"build:all": "npm run build:frontend && npm run build:backend",
		"build:frontend": "cd frontend && npm run build",
		"build:backend": "cd backend && npm run build",
		"start:all": "concurrently \"npm run start:frontend\" \"npm run start:backend\" --names \"FRONTEND,BACKEND\" --prefix-colors \"cyan,magenta\"",
		"start:frontend": "cd frontend && npm run start",
		"start:backend": "cd backend && npm run start:prod",
		"install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
		"lint:all": "npm run lint:frontend && npm run lint:backend",
		"lint:frontend": "cd frontend && npm run lint",
		"lint:backend": "cd backend && npm run lint",
		"test:all": "concurrently \"npm run test:frontend\" \"npm run test:backend\" --names \"FRONTEND_TEST,BACKEND_TEST\" --prefix-colors \"cyan,magenta\"",
		"test:frontend": "cd frontend && npm run test",
		"test:backend": "cd backend && npm run test",
		"test:e2e": "cd backend && npm run test:e2e",
		"docker:dev": "docker-compose up --build",
		"docker:dev:detached": "docker-compose up -d --build",
		"docker:dev:down": "docker-compose down",
		"docker:prod": "docker-compose -f docker-compose.prod.yml up --build",
		"docker:prod:detached": "docker-compose -f docker-compose.prod.yml up -d --build",
		"docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
		"docker:logs": "docker-compose logs -f",
		"docker:clean": "docker-compose down -v"
	},
	"devDependencies": {
		"concurrently": "^9.1.0"
	},
	"engines": {
		"node": ">=18.0.0",
		"npm": ">=9.0.0"
	}
}
